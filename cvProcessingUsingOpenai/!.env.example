# =============================================================================
# AI RESUME PROCESSOR - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains sensitive information!
# =============================================================================

# -----------------------------------------------------------------------------
# OPENAI CONFIGURATION
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# AWS CONFIGURATION
# -----------------------------------------------------------------------------
# AWS Region (e.g., us-east-1, ap-south-1, eu-west-1)
AWS_REGION=ap-south-1

# AWS IAM Credentials
# Create an IAM user with permissions for:
# - AmazonSQS (ReceiveMessage, DeleteMessage, SendMessage)
# - AmazonTextract (StartDocumentTextDetection, GetDocumentTextDetection)
# - AmazonS3 (GetObject for resume files)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# -----------------------------------------------------------------------------
# SQS QUEUE CONFIGURATION
# -----------------------------------------------------------------------------
# Input Queue - Where job postings and candidate details arrive
QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/input-queue

# Output Queue - Where evaluation results are sent
RESPONSE_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/output-queue

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# FastAPI Application Settings
APP_TITLE=AI Resume Processor
APP_VERSION=1.0.0
DESCRIPTION=AI-powered resume evaluation system using OpenAI GPT-4

# Debug Mode - Set to False in production
IS_DEBUG=True

# -----------------------------------------------------------------------------
# OPTIONAL: ADDITIONAL CONFIGURATION
# -----------------------------------------------------------------------------
# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# SQS Polling Interval (seconds)
POLLING_INTERVAL=10

# SQS Message Visibility Timeout (seconds)
VISIBILITY_TIMEOUT=30

# Maximum messages to process per batch
MAX_MESSAGES=1
